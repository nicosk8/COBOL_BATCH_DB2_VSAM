                   END-IF

                 ELSE
                   DISPLAY 'EL TIPO DE CLIENTE ES ERRONEO'
                   SET WS-NO TO TRUE

                 END-IF

               ELSE
                 DISPLAY 'LA SUCURSAL ES ERRONEA'
                 SET WS-NO TO TRUE

               END-IF

             ELSE
               DISPLAY 'EL NRO DE DOCUMENTO ES ERRONEO'
               SET WS-NO TO TRUE

             END-IF

           ELSE
             DISPLAY 'EL TIPO DE DOCUMENTO ES ERRONEO'
             SET WS-NO TO TRUE

