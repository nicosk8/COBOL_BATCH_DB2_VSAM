           WHEN '10'                                                    00082700
               SET WS-FIN-LECTURA TO TRUE                               00082802

           WHEN OTHER                                                   00083000
               DISPLAY '* ERROR EN LECTURA CLIENTE= ' WS-CLI-CODE       00083100
               MOVE 9999 TO RETURN-CODE                                 00083200
               SET WS-FIN-LECTURA TO TRUE                               00083300
                                                                        00083400
           END-EVALUATE.                                                00083500

       3000-F-LEER-CLI. EXIT.                                           00083700
                                                                        00083800
