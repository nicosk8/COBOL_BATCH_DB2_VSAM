      *                                    *                            00061900
      **************************************                            00062000
       1000-INICIO.                                                     00062100

           SET WS-NO-FIN-LECTURA TO TRUE.                               00070200

           OPEN INPUT  CLIENTE.                                         00071000

           IF WS-CLI-CODE IS NOT EQUAL '00'                             00071100
              DISPLAY '* ERROR EN OPEN CLIENTE = ' WS-CLI-CODE          00071200
              MOVE 9999 TO RETURN-CODE                                  00071300
              SET  WS-FIN-LECTURA TO TRUE                               00071400
           ELSE
              PERFORM 3000-I-LEER-CLI   THRU 3000-F-LEER-CLI
           END-IF.                                                      00071500
                                                                        00075600
       F-1000-INICIO.   EXIT.                                           00076800
                                                                        00076900
      **************************************                            00077000
      *  CUERPO PRINCIPAL DE PROCESOS      *                            00077200
      **************************************                            00077600
       2000-PROCESO.                                                    00077700

           MOVE WK-CLI-TIPO-DOCUMENTO        TO WT-TIPDOC
           MOVE WK-CLI-NRO-DOCUMENTO         TO WT-NRODOC
           MOVE WK-CLI-NRO-CLIENTE           TO WT-NROCLI
           MOVE WK-CLI-NOMBRE-CLIENTE(1:15)  TO WT-NOMAPE(1:15)
           MOVE WK-CLI-NOMBRE-CLIENTE(1:15)  TO WT-NOMAPE(16:15)
           MOVE WK-CLI-SEXO(1:1)             TO WT-SEXO

           MOVE WK-CLI-FECHA-NACIMIENTO(7:2)      TO WK-FECNAC-AA
           MOVE WK-CLI-FECHA-NACIMIENTO(4:2)      TO WK-FECNAC-MM
           MOVE WK-CLI-FECHA-NACIMIENTO(1:2)      TO WK-FECNAC-DD
           MOVE WK-FECNAC-DB2-AUX                 TO WT-FECNAC

             EXEC SQL INSERT
                      INTO KC02803.TBCURCLI
                 (TIPDOC, NRODOC, NROCLI, NOMAPE, FECNAC, SEXO)

                   VALUES (:WT-TIPDOC,
                           :WT-NRODOC,
                           :WT-NROCLI,
                           :WT-NOMAPE,
                           :WT-FECNAC,
                           :WT-SEXO)
             END-EXEC.

           IF SQLCODE = -803
                MOVE SQLCODE TO WS-SQL-EDIT
                DISPLAY 'REGISTRO DUPLICADO: ' WS-SQL-EDIT
                ADD 1  TO WS-NOVEDADES-DUPLICADOS
           ELSE
                IF SQLCODE = 0
                   DISPLAY 'INSERT OK ' WT-TIPDOC, WT-NRODOC
                   ADD 1  TO WS-NOVEDADES-INSERT
                ELSE
                   MOVE SQLCODE TO WS-SQL-EDIT
                   DISPLAY 'ERROR DB2: ' WS-SQL-EDIT
                   EXEC SQL ROLLBACK END-EXEC
                   SET WS-FIN-LECTURA TO TRUE
                END-IF
           END-IF

           PERFORM 3000-I-LEER-CLI   THRU 3000-F-LEER-CLI.

       F-2000-PROCESO. EXIT.
